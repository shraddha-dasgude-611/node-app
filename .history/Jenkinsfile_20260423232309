pipeline {
    agent any

    stages {

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t node-app:latest .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f node-app-container || true'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d --name node-app-container -p 3000:3000 node-app:latest'
            }
        }
    }
}